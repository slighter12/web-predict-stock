# PostgreSQL Database Connection Settings
# These variables are used in backend/database.py

# The username for the PostgreSQL database
POSTGRES_USER=user

# The password for the PostgreSQL database
POSTGRES_PASSWORD=password

# The hostname of the database server.
# Use 'localhost' when running scripts from the host machine.
# Use 'db' when running inside a Docker container on the same network.
POSTGRES_HOST=localhost

# The port the PostgreSQL server is listening on
POSTGRES_PORT=5432

# The name of the database to connect to
POSTGRES_DB=quant_platform

# Allowed frontend origins for FastAPI CORS handling
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional TWSE MIS TLS configuration for the tick archive provider.
# If TWSE MIS requires a custom CA bundle in your environment, point this to the file path.
TWSE_MIS_CA_BUNDLE=

# Optional CA cache path used when auto-downloading the TWSE MIS CA bundle.
TWSE_MIS_CA_CACHE_PATH=

# Optional trusted source for the CA bundle file.
TWSE_MIS_CA_BUNDLE_URL=

# If true, a TLS verification failure can trigger a one-time CA bundle download and retry.
TWSE_MIS_CA_AUTO_DOWNLOAD=false

# Development-only fallback. Set to true only if you explicitly want to skip TLS verification.
TWSE_MIS_SKIP_TLS_VERIFY=false

# Emergency-only fallback. Set to true only if you explicitly want an automatic
# retry without TLS verification after CA validation fails.
TWSE_MIS_ENABLE_INSECURE_FALLBACK=false
