# PostgreSQL Database Connection Settings
# These variables are used in backend/database.py

# The username for the PostgreSQL database
POSTGRES_USER=user

# The password for the PostgreSQL database
POSTGRES_PASSWORD=password

# The hostname of the database server.
# Use 'localhost' when running scripts from the host machine.
# Use 'db' when running inside a Docker container on the same network.
POSTGRES_HOST=localhost

# The port the PostgreSQL server is listening on
POSTGRES_PORT=5432

# The name of the database to connect to
POSTGRES_DB=quant_platform

# Allowed frontend origins for FastAPI CORS handling
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
